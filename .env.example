# External SMTP server used to relay contact-form submissions.
# Copy to `.env` and fill in real credentials. If SMTP_HOST is left blank,
# the form still works but messages are logged instead of sent.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey-or-username
SMTP_PASSWORD=your-smtp-password

# Use exactly one of these depending on the port:
#   port 587 -> STARTTLS:    SMTP_START_TLS=true,  SMTP_USE_TLS=false
#   port 465 -> implicit TLS: SMTP_START_TLS=false, SMTP_USE_TLS=true
SMTP_START_TLS=true
SMTP_USE_TLS=false

# Envelope / routing
MAIL_FROM=Wheelers <noreply@wheele.rs>
CONTACT_TO=sergeykanafyev@gmail.com
